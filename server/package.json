{
  "name": "lahore-zoo-server",
  "version": "1.0.0",
  "description": "Lahore Zoo Express Backend — MVC + N-Tier Architecture",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "seed": "node src/utils/seedData.js",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand --forceExit --passWithNoTests",
    "test:unit": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js tests/unit --runInBand --passWithNoTests",
    "test:integration": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js tests/integration --runInBand --forceExit --passWithNoTests",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage --runInBand --forceExit --passWithNoTests"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.14.1",
    "multer": "^1.4.5-lts.2",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.2",
    "jest": "^30.0.2",
    "mongodb-memory-server": "^10.4.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.0"
  }
}
